{
    "name": "stanford-version-control",
    "version": "1.0.0",
    "description": "史丹專屬版控平台 - 一鍵推送到 GitHub/GitLab/Gitee",
    "main": "electron-main.js",
    "scripts": {
        "start": "node server.js",
        "dev": "node server.js",
        "electron": "electron .",
        "build:mac": "electron-builder --mac",
        "build:win": "electron-builder --win",
        "build:all": "electron-builder --mac --win",
        "pack": "electron-builder --dir"
    },
    "build": {
        "appId": "com.stanford.version-control",
        "productName": "史丹版控平台",
        "directories": {
            "output": "dist"
        },
        "files": [
            "electron-main.js",
            "server.js",
            "package.json",
            "public/**/*",
            "node_modules/**/*"
        ],
        "mac": {
            "category": "public.app-category.developer-tools",
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "universal"
                    ]
                }
            ],
            "icon": "public/icon.png"
        },
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "public/icon.png"
        },
        "nsis": {
            "oneClick": true,
            "allowToChangeInstallationDirectory": false,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "史丹版控平台"
        }
    },
    "dependencies": {
        "cors": "^2.8.5",
        "express": "^4.21.0"
    },
    "devDependencies": {
        "electron": "^33.0.0",
        "electron-builder": "^25.1.8"
    }
}